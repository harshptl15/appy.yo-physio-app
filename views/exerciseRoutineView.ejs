<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Routine</title>
    <link rel="stylesheet" href="css/routine.css"/>
    <link rel="stylesheet" href="css/sidebar-shell.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script src="/js/language.js?v=4"></script>
</head>
<body>
    <div class="overlay">
        <button class="hamburger" id="hamburgerBtn">☰</button>
        <%- include('partials/sidebar-shell') %>
        <div class="routine-card animate__animated animate__zoomIn">
            <h1 class="animate__animated animate__fadeInDown" data-i18n="routine.title">Your Exercise Routine</h1>
            <% if (workoutPlanMetadata) { %>
              <div class="routine-box" style="margin-bottom: 0.8rem;">
                <p><strong>Session plan:</strong> Warmup + <%= workoutPlanMetadata.selectedExercises %> exercises</p>
                <p>
                  Estimated duration: <%= workoutPlanMetadata.estimatedDurationMinutes %> min
                  (Preference: <%= workoutPlanMetadata.durationPreferenceMinutes %> min)
                </p>
              </div>
            <% } %>
        <!-- exerciseRoutine is an array of objects with exerciseName properties passed from the controller.
         so far this list does nothing other than dispaly the values passed by the array. -->
         <!-- select is no longer good for the view, i am replacing it with divs -->
            <!-- <select name="exerciseRoutine" id="exerciseRoutine" multiple>
                <% exerciseRoutine.forEach(function(exercise) { %>
                <option value="<%= exercise.exerciseName %>">
                    <%= exercise.exerciseName %>
                </option>
                <% }); %>
            </select>
        </div> -->
        <!-- div for showing a list of all exercises in routine. -->
         <div class="routine-list">
            <% exerciseRoutine.forEach((exercise, i) => { %>
                <div class="routine-box <%= exercise.goal ? 'completed' : '' %> <%= !allExercisesCompleted && currentExercise && currentExercise.id === exercise.id ? 'active' : '' %>" data-routine-exercise-card data-exercise-id="<%= exercise.id %>">
                    <p class="exercise-name" data-exercise-name="<%= exercise.exerciseName %>"><%= exercise.exerciseName %></p>
                    <!-- only render the following image if the exercise.goal is true 
                    and therefore this exercise has been completed-->
                    <% if (exercise.goal) { %>
                    <span class="checkmark">✔</span>
                        <p class="status-text" data-i18n="common.completed">Completed</p>
                    <% } else { %>
                      <form action="/markExerciseAsFinished" method="POST" class="mark-complete-form">
                        <input type="hidden" name="finishedExerciseId" value="<%= exercise.id %>">
                        <button type="submit" class="btn btn-success mark-complete-btn" data-exercise-id="<%= exercise.id %>" data-i18n="routine.markComplete">Mark as Complete</button>
                      </form>
                    <% } %>
                </div>
            <% }) %>
         </div>
        <!-- div for buttons to control the entire routine -->
        <div class="btn-group">
            <form action="/restartRoutine" method="POST">
                <button type="submit" class="btn btn-primary" data-i18n="routine.restart">Restart Routine</button>
            </form>
                <a href="/category" class="link-btn" data-i18n="routine.newSearch">🆕 New Search</a>
                <a href="/resetAndNewSearch" class="link-btn" data-i18n="exercises.resetNewSearch">♻ Reset & New Search</a>
                <a href="/getAndShowFavourites" class="link-btn" data-i18n="routine.showFavourites">⭐ Show Favourites</a>
        </div>
         <!-- div for new search -->
         <!-- if all exercises in the routine are completed, show a message -->

        <% if (allExercisesCompleted) { %>
        <div class="all-exercises-completed success-alert">
            <p><span class="success-icon" aria-hidden="true">✓</span> <span data-i18n="routine.allCompleted">All exercises in your routine are completed!</span></p>
        </div>
        <% if (showPainFeedbackPrompt && activeWorkoutSessionId) { %>
          <div class="current-exercise pain-feedback-shell" id="painFeedbackCard">
            <h2 class="pain-feedback-title" data-i18n="routine.painCheckin.title">Post-workout pain check-in</h2>
            <p class="pain-feedback-subtitle">Help us tailor your next session by sharing how you feel.</p>
            <form id="painFeedbackForm">
              <input type="hidden" id="workoutSessionId" value="<%= activeWorkoutSessionId %>">

              <div class="form-row">
                <label for="painScore"><strong>Pain level (0-10)</strong></label>
                <div class="pain-score-display">
                  <span id="painScoreValue">0</span>
                </div>
                <input
                  type="range"
                  id="painScore"
                  min="0"
                  max="10"
                  step="1"
                  value="0"
                  required
                  list="painScoreTicks"
                  class="pain-slider"
                >
                <datalist id="painScoreTicks">
                  <option value="0"></option>
                  <option value="1"></option>
                  <option value="2"></option>
                  <option value="3"></option>
                  <option value="4"></option>
                  <option value="5"></option>
                  <option value="6"></option>
                  <option value="7"></option>
                  <option value="8"></option>
                  <option value="9"></option>
                  <option value="10"></option>
                </datalist>
                <p class="field-microcopy">0 = no pain, 10 = severe pain</p>
              </div>

              <div class="form-row">
                <label for="painTrend"><strong>Compared to before workout</strong></label>
                <div class="segmented-control" role="group" aria-label="Compared to before workout">
                  <button type="button" class="segment-btn" data-trend-value="better">Felt better</button>
                  <button type="button" class="segment-btn" data-trend-value="same">No change</button>
                  <button type="button" class="segment-btn" data-trend-value="worse">Felt worse</button>
                </div>
                <select id="painTrend" required class="visually-hidden-input">
                  <option value="">Select trend</option>
                  <option value="better">Felt better</option>
                  <option value="same">Felt the same</option>
                  <option value="worse">Felt worse</option>
                </select>
              </div>

              <div class="form-row">
                <label for="painNotes"><strong>Notes (optional)</strong></label>
                <textarea id="painNotes" rows="2" maxlength="500" placeholder="Anything else you noticed?" class="pain-notes"></textarea>
              </div>

              <p id="painFeedbackValidation" class="validation-message" aria-live="polite"></p>
              <button type="submit" class="btn btn-primary pain-submit-btn" id="painFeedbackSubmitBtn" data-i18n="routine.painCheckin.submit">Submit pain feedback</button>
              <p id="painFeedbackStatus" class="pain-status" aria-live="polite"></p>
            </form>
          </div>
        <% } else if (!painFeedbackAfterWorkoutsEnabled) { %>
          <div class="all-exercises-completed">
            <p data-i18n="routine.painCheckin.disabled">Pain check-in is disabled in your settings. Workout completed successfully.</p>
          </div>
        <% } %>
        <!-- div for buttons to control the current exercise in the routine. -->
        <% } else { %>
            <section class="current-exercise" id="currentExercisePanel" data-current-exercise-id="<%= currentExercise.id %>">
                <h2 data-i18n="routine.nowTraining">Now Training</h2>
                <p class="current-exercise-title">
                  <strong id="currentExerciseName" class="exercise-name" data-exercise-name="<%= currentExercise.exerciseName %>"><%= currentExercise.exerciseName %></strong>
                </p>
                <ul class="current-exercise-details">
                    <li><strong>💡 Tips:</strong> <span id="currentExerciseTips"><%= currentExercise.tips || 'Not available' %></span></li>
                    <li><strong>⚠ Common Mistakes:</strong> <span id="currentExerciseCommonMistakes"><%= currentExercise.commonMistakes || 'Not available' %></span></li>
                    <li><strong>🏋 Equipment:</strong> <span id="currentExerciseEquipment"><%= currentExercise.equipment || 'Not available' %></span></li>
                    <li><strong>📏 Sets/Reps:</strong> <span id="currentExerciseSetsReps"><%= currentExercise.sets || '-' %> × <%= currentExercise.reps || '-' %></span></li>
                    <li><strong>⏱ Tempo/Hold Time:</strong> <span id="currentExerciseTempo"><%= currentExercise.tempo || 'Not available' %></span></li>
                    <li><strong>🎯 Skill Level:</strong> <span id="currentExerciseSkillLevel"><%= currentExercise.skillLevel || 'Not available' %></span></li>
                    <li><strong>📍 Position:</strong> <span id="currentExercisePosition"><%= currentExercise.position || 'Not available' %></span></li>
                    <li><strong>🖼 Image:</strong> <a id="currentExerciseImageLink" href="<%= currentExercise.image || '#' %>" target="_blank" rel="noopener noreferrer"><%= currentExercise.image || 'Not available' %></a></li>
                    <li><strong>🎥 Video:</strong> <a id="currentExerciseVideoLink" href="<%= currentExercise.video || '#' %>" target="_blank" rel="noopener noreferrer"><%= currentExercise.video || 'Not available' %></a></li>
                </ul>
                <p id="currentExerciseStatus" class="current-exercise-status" aria-live="polite"></p>
                <div class="exercise-actions">
                    <form id="removeCurrentExerciseForm" action="/removeExerciseFromRoutine" method="POST">
                        <input id="removeCurrentExerciseId" type="hidden" name="exerciseId" value="<%= currentExercise.id %>">
                        <button type="submit" class="btn btn-danger" data-i18n="routine.removeCurrent">Remove Current Exercise</button>
                    </form>
                    <form id="markCurrentExerciseCompleteForm" action="/markExerciseAsFinished" method="POST">
                        <input id="markCurrentExerciseId" type="hidden" name="finishedExerciseId" value="<%= currentExercise.id %>">
                        <button type="submit" class="btn btn-success" data-i18n="routine.markComplete">Mark as Complete</button>
                    </form>
                    <form id="addCurrentExerciseFavouriteForm" action="/addExerciseToFavouritesThenShowFavourites" method="POST">
                        <input id="favouriteCurrentExerciseId" type="hidden" name="favouriteExerciseId" value="<%= currentExercise.id %>">
                        <button type="submit" class="btn btn-secondary" data-i18n="routine.addToFavourites">Add to Favourites</button>
                    </form>
                </div>
            </section>
        <% } %>
    </div>
    <script id="routineStatePayload" type="application/json"><%- JSON.stringify(exerciseRoutine).replace(/</g, '\\u003c') %></script>
    <script>
        const applyDynamicTranslations = () => {
          if (!window.PhysioLanguage || typeof window.PhysioLanguage.translateDynamic !== 'function') return;
          const language = window.PhysioLanguage.getLanguagePreference();
          document.querySelectorAll('.exercise-name[data-exercise-name]').forEach((el) => {
            const raw = el.getAttribute('data-exercise-name');
            el.textContent = window.PhysioLanguage.translateDynamic('exercise', raw, language);
          });
        };

        applyDynamicTranslations();
        window.addEventListener('physio-language-changed', applyDynamicTranslations);

        const safeText = (value, fallback = 'Not available') => {
          const normalized = typeof value === 'string' ? value.trim() : value;
          return normalized ? String(normalized) : fallback;
        };

        const payloadEl = document.getElementById('routineStatePayload');
        const currentExercisePanel = document.getElementById('currentExercisePanel');
        let routineState = [];
        if (payloadEl && payloadEl.textContent) {
          try {
            const parsed = JSON.parse(payloadEl.textContent);
            if (Array.isArray(parsed)) {
              routineState = parsed;
            }
          } catch (error) {
            console.error('Failed to parse routine payload:', error);
          }
        }

        let currentExerciseId = Number(currentExercisePanel?.dataset.currentExerciseId || 0);

        const getExerciseById = (exerciseId) => routineState.find((exercise) => Number(exercise.id) === Number(exerciseId)) || null;
        const getNextIncompleteExercise = () => routineState.find((exercise) => !exercise.goal) || null;

        const setStatus = (message, isError = false) => {
          const statusEl = document.getElementById('currentExerciseStatus');
          if (!statusEl) return;
          statusEl.textContent = message || '';
          statusEl.style.color = isError ? '#fca5a5' : '#cbd5e1';
        };

        const updateMediaLink = (linkId, value) => {
          const linkEl = document.getElementById(linkId);
          if (!linkEl) return;
          const hasValue = typeof value === 'string' && value.trim().length > 0;
          linkEl.href = hasValue ? value : '#';
          linkEl.textContent = hasValue ? value : 'Not available';
          linkEl.classList.toggle('disabled-link', !hasValue);
          if (!hasValue) {
            linkEl.removeAttribute('target');
            linkEl.removeAttribute('rel');
          } else {
            linkEl.setAttribute('target', '_blank');
            linkEl.setAttribute('rel', 'noopener noreferrer');
          }
        };

        const markCardAsCompleted = (exerciseId) => {
          const card = document.querySelector(`[data-routine-exercise-card][data-exercise-id="${exerciseId}"]`);
          if (!card) return;

          card.classList.remove('active');
          card.classList.add('completed');

          const markForm = card.querySelector('.mark-complete-form');
          if (markForm) {
            markForm.remove();
          }

          if (!card.querySelector('.checkmark')) {
            const checkmark = document.createElement('span');
            checkmark.className = 'checkmark';
            checkmark.textContent = '✔';
            card.appendChild(checkmark);
          }

          if (!card.querySelector('.status-text')) {
            const statusText = document.createElement('p');
            statusText.className = 'status-text';
            statusText.setAttribute('data-i18n', 'common.completed');
            statusText.textContent = window.PhysioLanguage?.t?.('common.completed') || 'Completed';
            card.appendChild(statusText);
          }
        };

        const removeCardByExerciseId = (exerciseId) => {
          const card = document.querySelector(`[data-routine-exercise-card][data-exercise-id="${exerciseId}"]`);
          if (card) card.remove();
        };

        const highlightActiveExerciseCard = (exerciseId) => {
          document.querySelectorAll('[data-routine-exercise-card]').forEach((card) => {
            const cardExerciseId = Number(card.dataset.exerciseId);
            card.classList.toggle('active', Number(exerciseId) === cardExerciseId);
          });
        };

        const setCurrentExercise = (exercise) => {
          if (!currentExercisePanel) return;

          if (!exercise) {
            currentExerciseId = 0;
            currentExercisePanel.classList.add('is-empty');
            const nameEl = document.getElementById('currentExerciseName');
            if (nameEl) {
              nameEl.textContent = 'No exercise in routine';
              nameEl.setAttribute('data-exercise-name', 'No exercise in routine');
            }
            document.getElementById('currentExerciseTips').textContent = 'No exercise selected.';
            document.getElementById('currentExerciseCommonMistakes').textContent = 'No exercise selected.';
            document.getElementById('currentExerciseEquipment').textContent = 'No exercise selected.';
            document.getElementById('currentExerciseSetsReps').textContent = '-';
            document.getElementById('currentExerciseTempo').textContent = '-';
            document.getElementById('currentExerciseSkillLevel').textContent = '-';
            document.getElementById('currentExercisePosition').textContent = '-';
            updateMediaLink('currentExerciseImageLink', '');
            updateMediaLink('currentExerciseVideoLink', '');
            setStatus('All exercises are complete.');
            return;
          }

          currentExercisePanel.classList.remove('is-empty');
          currentExerciseId = Number(exercise.id);
          currentExercisePanel.dataset.currentExerciseId = String(currentExerciseId);
          highlightActiveExerciseCard(currentExerciseId);

          const currentNameEl = document.getElementById('currentExerciseName');
          currentNameEl.textContent = safeText(exercise.exerciseName, 'Unnamed exercise');
          currentNameEl.setAttribute('data-exercise-name', safeText(exercise.exerciseName, 'Unnamed exercise'));

          document.getElementById('currentExerciseTips').textContent = safeText(exercise.tips);
          document.getElementById('currentExerciseCommonMistakes').textContent = safeText(exercise.commonMistakes);
          document.getElementById('currentExerciseEquipment').textContent = safeText(exercise.equipment);
          document.getElementById('currentExerciseSetsReps').textContent = `${safeText(exercise.sets, '-')} × ${safeText(exercise.reps, '-')}`;
          document.getElementById('currentExerciseTempo').textContent = safeText(exercise.tempo);
          document.getElementById('currentExerciseSkillLevel').textContent = safeText(exercise.skillLevel);
          document.getElementById('currentExercisePosition').textContent = safeText(exercise.position);
          updateMediaLink('currentExerciseImageLink', exercise.image);
          updateMediaLink('currentExerciseVideoLink', exercise.video);

          const removeInput = document.getElementById('removeCurrentExerciseId');
          const markInput = document.getElementById('markCurrentExerciseId');
          const favouriteInput = document.getElementById('favouriteCurrentExerciseId');
          if (removeInput) removeInput.value = String(currentExerciseId);
          if (markInput) markInput.value = String(currentExerciseId);
          if (favouriteInput) favouriteInput.value = String(currentExerciseId);

          const favouriteButton = document.querySelector('#addCurrentExerciseFavouriteForm button[type="submit"]');
          if (favouriteButton) {
            favouriteButton.disabled = false;
            favouriteButton.textContent = window.PhysioLanguage?.t?.('routine.addToFavourites') || 'Add to Favourites';
          }

          setStatus('');
          applyDynamicTranslations();
        };

        const markExerciseComplete = async (exerciseId, triggerButton) => {
          const button = triggerButton;
          const originalLabel = button ? button.textContent : '';
          if (button) {
            button.disabled = true;
            button.textContent = 'Saving...';
          }

          try {
            const response = await fetch('/markExerciseAsFinished', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json'
              },
              body: JSON.stringify({ finishedExerciseId: Number(exerciseId) })
            });

            if (!response.ok) {
              throw new Error('Failed to mark exercise as complete.');
            }

            routineState = routineState.map((exercise) => {
              if (Number(exercise.id) === Number(exerciseId)) {
                return { ...exercise, goal: true };
              }
              return exercise;
            });

            markCardAsCompleted(exerciseId);
            const nextExercise = getNextIncompleteExercise();
            if (!nextExercise) {
              window.location.reload();
              return;
            }
            setCurrentExercise(nextExercise);
            setStatus('Exercise marked as complete.');
          } catch (error) {
            setStatus(error.message || 'Failed to mark exercise as complete.', true);
            if (button) {
              button.disabled = false;
              button.textContent = originalLabel;
            }
          }
        };

        document.querySelectorAll('.mark-complete-form').forEach((form) => {
          form.addEventListener('submit', async (event) => {
            event.preventDefault();
            const hiddenInput = form.querySelector('input[name="finishedExerciseId"]');
            const button = form.querySelector('button[type="submit"]');
            const exerciseId = Number(hiddenInput?.value);
            if (!Number.isInteger(exerciseId) || exerciseId <= 0 || !button) return;
            await markExerciseComplete(exerciseId, button);
          });
        });

        const removeCurrentExerciseForm = document.getElementById('removeCurrentExerciseForm');
        if (removeCurrentExerciseForm) {
          removeCurrentExerciseForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!Number.isInteger(currentExerciseId) || currentExerciseId <= 0) return;

            const button = removeCurrentExerciseForm.querySelector('button[type="submit"]');
            const originalLabel = button?.textContent || '';
            if (button) {
              button.disabled = true;
              button.textContent = 'Removing...';
            }

            try {
              const response = await fetch('/removeExerciseFromRoutine', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  Accept: 'application/json'
                },
                body: JSON.stringify({ exerciseId: currentExerciseId })
              });

              if (!response.ok) {
                throw new Error('Failed to remove current exercise.');
              }

              routineState = routineState.filter((exercise) => Number(exercise.id) !== Number(currentExerciseId));
              removeCardByExerciseId(currentExerciseId);

              const nextExercise = getNextIncompleteExercise();
              if (!nextExercise) {
                window.location.reload();
                return;
              }
              setCurrentExercise(nextExercise);
              setStatus('Current exercise removed.');
            } catch (error) {
              setStatus(error.message || 'Failed to remove current exercise.', true);
              if (button) {
                button.disabled = false;
                button.textContent = originalLabel;
              }
            }
          });
        }

        const markCurrentExerciseCompleteForm = document.getElementById('markCurrentExerciseCompleteForm');
        if (markCurrentExerciseCompleteForm) {
          markCurrentExerciseCompleteForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!Number.isInteger(currentExerciseId) || currentExerciseId <= 0) return;
            const button = markCurrentExerciseCompleteForm.querySelector('button[type="submit"]');
            await markExerciseComplete(currentExerciseId, button);
          });
        }

        const addCurrentExerciseFavouriteForm = document.getElementById('addCurrentExerciseFavouriteForm');
        if (addCurrentExerciseFavouriteForm) {
          addCurrentExerciseFavouriteForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!Number.isInteger(currentExerciseId) || currentExerciseId <= 0) return;

            const button = addCurrentExerciseFavouriteForm.querySelector('button[type="submit"]');
            const originalLabel = button?.textContent || '';
            if (button) {
              button.disabled = true;
              button.textContent = 'Saving...';
            }

            try {
              const response = await fetch('/addExerciseToFavouritesThenShowFavourites', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  Accept: 'application/json'
                },
                body: JSON.stringify({ favouriteExerciseId: currentExerciseId })
              });
              const result = await response.json();
              if (!response.ok) {
                throw new Error(result.error || 'Failed to add exercise to favourites.');
              }

              if (button) {
                button.disabled = true;
                button.textContent = result.added
                  ? (window.PhysioLanguage?.t?.('routine.addedToFavourites') || 'Added to Favourites')
                  : (window.PhysioLanguage?.t?.('routine.alreadyFavourite') || 'Already in favourites');
              }
              setStatus('Favourites updated.');
            } catch (error) {
              setStatus(error.message || 'Failed to add to favourites.', true);
              if (button) {
                button.disabled = false;
                button.textContent = originalLabel;
              }
            }
          });
        }

        if (currentExercisePanel) {
          const initialCurrentExercise = getExerciseById(currentExerciseId) || getNextIncompleteExercise();
          setCurrentExercise(initialCurrentExercise);
        }

        const painFeedbackForm = document.getElementById('painFeedbackForm');
        if (painFeedbackForm) {
          const painScoreInput = document.getElementById('painScore');
          const painScoreValue = document.getElementById('painScoreValue');
          const painTrendSelect = document.getElementById('painTrend');
          const trendButtons = document.querySelectorAll('.segment-btn');
          const validationEl = document.getElementById('painFeedbackValidation');
          const submitBtn = document.getElementById('painFeedbackSubmitBtn');

          const updateSliderVisualState = () => {
            const value = Number(painScoreInput.value);
            painScoreValue.textContent = String(value);
            painScoreInput.style.setProperty('--score', value);
          };

          trendButtons.forEach((button) => {
            button.addEventListener('click', () => {
              painTrendSelect.value = button.dataset.trendValue || '';
              trendButtons.forEach((item) => item.classList.remove('selected'));
              button.classList.add('selected');
            });
          });

          painScoreInput.addEventListener('input', () => {
            updateSliderVisualState();
            validationEl.textContent = '';
          });

          painTrendSelect.addEventListener('change', () => {
            validationEl.textContent = '';
          });

          updateSliderVisualState();

          painFeedbackForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            const statusEl = document.getElementById('painFeedbackStatus');
            const painScore = Number(document.getElementById('painScore').value);
            const trend = document.getElementById('painTrend').value;
            validationEl.textContent = '';
            statusEl.textContent = '';

            if (!Number.isInteger(painScore) || painScore < 0 || painScore > 10) {
              validationEl.textContent = 'Please select a pain score between 0 and 10.';
              validationEl.style.color = '#f8a5a5';
              return;
            }

            if (!trend) {
              validationEl.textContent = 'Please choose how you felt compared to before workout.';
              validationEl.style.color = '#f8a5a5';
              return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Saving...';
            statusEl.textContent = 'Saving...';
            statusEl.style.color = '#1f3a5a';

            const payload = {
              workoutSessionId: Number(document.getElementById('workoutSessionId').value),
              painScore,
              trend,
              notes: document.getElementById('painNotes').value.trim()
            };

            try {
              const response = await fetch('/api/workouts/pain-feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
              const result = await response.json();

              if (!response.ok) {
                throw new Error(result.error || 'Failed to save pain feedback.');
              }

              statusEl.textContent = 'Saved. Next workout progression has been updated.';
              statusEl.style.color = '#1e7b4f';
              setTimeout(() => window.location.reload(), 600);
            } catch (error) {
              statusEl.textContent = error.message || 'Failed to save pain feedback.';
              statusEl.style.color = '#9b1c1c';
            } finally {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Submit pain feedback';
            }
          });
        }
    </script>
</body>
</html>
