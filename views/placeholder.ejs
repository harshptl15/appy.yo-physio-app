<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="/js/language.js?v=4"></script>
  <style>
    body { margin: 0; font-family: Inter, "Segoe UI", Arial, sans-serif; background: #edf2f7; color: #15253b; }
    .wrap { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .card { width: min(640px, 100%); background: #fff; border: 1px solid #d7e2eb; border-radius: 24px; box-shadow: 0 20px 50px -28px rgba(10, 31, 61, 0.35); padding: 32px; }
    h1 { margin: 0 0 12px; font-size: 1.8rem; }
    p { margin: 0; color: #5f7287; line-height: 1.6; }
    a { display: inline-block; margin-top: 20px; color: #0f8f8d; font-weight: 600; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1 data-i18n="<%= headingKey %>">Coming soon</h1>
      <p data-i18n="<%= bodyKey %>">This page is not available yet.</p>
      <a href="/login" data-i18n="placeholder.backLogin">Back to sign in</a>
    </div>
  </div>
</body>
</html>
